local pages = {}

local function createPage(name)
    local page = Instance.new("Frame")
    page.Name                   = name .. "Page"
    page.Size                   = UDim2.new(1, 0, 1, 0)
    page.Position               = UDim2.new(0, 0, 0, 0)
    page.BackgroundTransparency = 1
    page.ZIndex                 = 11
    page.ClipsDescendants       = true
    page.Parent                 = content
    page.Visible                = false
    pages[name] = page
    return page
end

local flightPage   = createPage("flight")
local speedPage    = createPage("speed")
local keybindsPage = createPage("keybinds")
local infoPage     = createPage("info")

local function setActiveTab(name)
    for tabName, page in pairs(pages) do
        page.Visible = tabName == name
    end
    for childIndex, child in ipairs(tabBar:GetChildren()) do
        if child:IsA("TextButton") then
            local active = child.Name == name
            child.BackgroundColor3 = active and Color3.fromRGB(35, 75, 170) or Color3.fromRGB(18, 22, 42)
            child.TextColor3       = active and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(170, 190, 230)
        end
    end
end

