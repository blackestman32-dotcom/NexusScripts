-- Animate loading
local spinAngle = 0
local spinConn = RunService.Heartbeat:Connect(function(dt)
    spinAngle = spinAngle + dt * 140
    ring.Rotation     = spinAngle
    ringOuter.Rotation = -spinAngle * 0.45
end)

-- Loading steps: {wait, barPct, stageText, statusText, checkIndex}
local loadSteps = {
    {t = 0.30, pct = 0.10, stage = "LOADING SERVICES",        status = "Binding game services...",           check = 1},
    {t = 0.40, pct = 0.22, stage = "LOADING CHARACTER",       status = "Waiting for character data...",      check = 2},
    {t = 0.40, pct = 0.38, stage = "LOADING PHYSICS ENGINE",  status = "Configuring BodyVelocity forces...", check = 3},
    {t = 0.45, pct = 0.55, stage = "BUILDING GUI",            status = "Constructing interface panels...",   check = 4},
    {t = 0.50, pct = 0.74, stage = "LOADING FLIGHT MODULE",   status = "Compiling flight routines...",       check = 5},
    {t = 0.45, pct = 0.90, stage = "BINDING INPUTS",          status = "Registering keybinds & hotkeys...",  check = 6},
    {t = 0.40, pct = 1.00, stage = "READY",                   status = "All systems operational.",           check = nil},
}

task.spawn(function()
    for stepIdx, step in ipairs(loadSteps) do
        task.wait(step.t)

        TweenService:Create(barFill, TweenInfo.new(0.35, Enum.EasingStyle.Quad), {
            Size = UDim2.new(step.pct, 0, 1, 0)
        }):Play()

        stageLabel.Text = step.stage
        loadStatus.Text = step.status

        -- Light up corresponding check item
        if step.check then
            local c = checkLabels[step.check]
            TweenService:Create(c.dot, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(55, 215, 115)}):Play()
            TweenService:Create(c.lbl, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(100, 210, 140)}):Play()
        end
    end

    -- Hold "READY" for a moment so user can see it
    task.wait(0.6)
    stageLabel.Text = "LAUNCH"
    loadStatus.Text = "Welcome. Enjoy your flight."
    task.wait(0.55)

    spinConn:Disconnect()

    -- Fade out
    TweenService:Create(loadFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {
        BackgroundTransparency = 1
    }):Play()
    for _, d in ipairs(loadFrame:GetDescendants()) do
        if d:IsA("TextLabel") then
            TweenService:Create(d, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        elseif d:IsA("Frame") then
            TweenService:Create(d, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
        end
    end

    task.wait(0.55)
    loadFrame:Destroy()
end)

