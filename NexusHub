    if on then
        TweenService:Create(flyBtn,      tweenEase, {BackgroundColor3 = Color3.fromRGB(185, 38, 38)}):Play()
        TweenService:Create(statusDot,   tweenEase, {BackgroundColor3 = Color3.fromRGB(55, 215, 115)}):Play()
        TweenService:Create(panelStroke, tweenEase, {Color            = Color3.fromRGB(55, 195, 110)}):Play()
        flyBtn.Text    = "■  STOP FLYING"
        statusVal.Text = "Flying"
        TweenService:Create(statusVal,   tweenEase, {TextColor3 = Color3.fromRGB(75, 215, 130)}):Play()
    else
        TweenService:Create(flyBtn,      tweenEase, {BackgroundColor3 = Color3.fromRGB(22, 96, 205)}):Play()
        TweenService:Create(statusDot,   tweenEase, {BackgroundColor3 = Color3.fromRGB(50, 60, 110)}):Play()
        TweenService:Create(panelStroke, tweenEase, {Color            = Color3.fromRGB(35, 70, 155)}):Play()
        flyBtn.Text    = "▶  START FLYING"
        statusVal.Text = "Idle"
        TweenService:Create(statusVal,   tweenEase, {TextColor3 = Color3.fromRGB(60, 75, 140)}):Play()
    end
end

local function toggleFly()
    flying = not flying
    if flying then enableFly() else disableFly() end
    setVisuals(flying)
end

-- ================================================
--  INTERACTIONS
-- ================================================
flyBtn.MouseButton1Click:Connect(toggleFly)
closeBtn.MouseButton1Click:Connect(function()
    if flying then
        disableFly()
        flying = false
        setVisuals(false)
    end
    if screenGui and screenGui.Parent then
        screenGui:Destroy()
    end
end)

flyBtn.MouseEnter:Connect(function()
    TweenService:Create(flyBtn, tweenEase, {BackgroundTransparency = 0.18}):Play()
end)
flyBtn.MouseLeave:Connect(function()
    TweenService:Create(flyBtn, tweenEase, {BackgroundTransparency = 0}):Play()
end)

UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.KeyCode == Enum.KeyCode.F then toggleFly() end
end)

player.CharacterAdded:Connect(function()
    flying = false
    setVisuals(false)
    bodyVelocity, bodyGyro = nil, nil
    if flyConnection then flyConnection:Disconnect(); flyConnection = nil end
    applyWalkSpeed()
end)
